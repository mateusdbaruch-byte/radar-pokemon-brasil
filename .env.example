# Reddit — OAuth (fonte opcional / gated)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=python:radar-pokemon-brasil:v0.1.0 (by /u/SEU_USUARIO)
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Busca web — API oficial (fluxo principal do Opportunity Radar)
# Valores: bing | google | serpapi
WEB_SEARCH_PROVIDER=
BING_SEARCH_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
SERPAPI_KEY=

# Controle de carga — web_search (Opportunity Radar)
WEB_SEARCH_TIMEOUT_SECONDS=20
WEB_SEARCH_DELAY_SECONDS=2
WEB_SEARCH_MAX_RETRIES=2
WEB_SEARCH_MAX_QUERIES_PER_RUN=20

# Orçamento SerpAPI — evita gasto descontrolado
SERPAPI_MONTHLY_BUDGET=250
SERPAPI_DAILY_BUDGET=20
SERPAPI_STOP_WHEN_BUDGET_REACHED=true

# YouTube Data API v3 (opcional)
YOUTUBE_API_KEY=

# Mercado Livre (API oficial)
MERCADOLIVRE_ACCESS_TOKEN=
MERCADOLIVRE_USER_AGENT=RadarPokemonBrasil/0.2 contato:seu-email

APP_ENV=local
DEFAULT_DATA_MODE=live
